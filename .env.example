# ─── Resend (изпращане на имейли) ───────────────────────────
# API ключ от https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Подател. Домейнът трябва да е верифициран в Resend.
FROM_EMAIL="Just Pablo <zapitvane@just-pablo.com>"

# Кой получава известията за нови запитвания (едно писмо до двамата).
TO_EMAIL_PRIMARY=adsjustpablo@gmail.com
TO_EMAIL_SECONDARY=

# Reply-To на потвърждението към клиента. ВАЖНО: трябва да е кутия, която
# реално приема поща — just-pablo.com няма MX записи, така че отговорите на
# zapitvane@just-pablo.com се губят.
CLIENT_REPLY_TO=adsjustpablo@gmail.com

# ─── Google reCAPTCHA v3 (по избор) ─────────────────────────
# Само маркира съмнителните заявки в имейла, никога не блокира.
# Без тези променливи формата работи нормално.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
